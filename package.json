{
  "name": "watson-cli",
  "version": "1.0.0",
  "description": "Bun-native TypeScript CLI framework",
  "type": "module",
  "bin": {
    "app": "./dist/cli.js"
  },
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "check": "fallow",
    "check:types": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.0",
    "fallow": "^2.100.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^6.0.3"
  }
}
